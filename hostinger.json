{
  "name": "gotek-idcard-cropping",
  "version": "1.0.0",
  "build": {
    "command": "npm install && npm run build",
    "output_directory": "dist"
  },
  "start": "node server.js",
  "environment": {
    "node_version": "22.x",
    "variables": {
      "MONGODB_URI": "required",
      "GEMINI_API_KEY": "required",
      "PORT": "5001"
    }
  },
  "framework": "node",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
